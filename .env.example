SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=replace-with-your-supabase-service-role-key
SCRAPER_API_KEY=replace-with-a-long-random-secret

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_RESULT_EXPIRES_SECONDS=3600

# Za direktni deploy koristi 8000.
# Za nginx/TLS na istoj masini stavi 127.0.0.1:8000.
APP_PORT=8000
APP_DOMAIN=api.example.com
PUBLIC_BASE_URL=https://api.example.com
SERVICE_NAME=Skrejper
CORS_ALLOW_ORIGINS=https://app.example.com

HEADLESS=true
BROWSER_CHANNEL=chromium

RESEND_API_KEY=
RESEND_FROM_EMAIL=
FIRECRAWL_API_KEY=
FIRECRAWL_INITIAL_ENRICHMENT_DELAY_HOURS=3
FIRECRAWL_RETRY_DELAY_HOURS=48
FIRECRAWL_TIMEOUT_SECONDS=45
FIRECRAWL_SCRAPE_TIMEOUT_MS=15000
FIRECRAWL_MAX_PAGES_PER_LEAD=3
